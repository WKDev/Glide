<?xml version="1.0" encoding="utf-8"?>
<!--
  AppxManifest template for MSIX packaging.
  {{PUBLISHER}} and {{VERSION}} are replaced at build time by the release workflow.

  MSIX_PUBLISHER secret:
    - For Microsoft Store submission: set to the Publisher DN from Partner Center
      e.g. "CN=00000000-0000-0000-0000-000000000000"
    - If the secret is unset, "CN=Glide" is used (unsigned build, Store-compatible).
    - For sideload distribution: must match the signing certificate Subject.
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap3 rescap">

  <Identity
    Name="com.wkdev.glide"
    Publisher="{{PUBLISHER}}"
    Version="{{VERSION}}"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Glide</DisplayName>
    <PublisherDisplayName>wkdev</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily
      Name="Windows.Desktop"
      MinVersion="10.0.17763.0"
      MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-US" />
  </Resources>

  <Applications>
    <Application Id="Glide" Executable="glide.exe" EntryPoint="Windows.FullTrustApplication">
      <uap3:VisualElements
        DisplayName="Glide"
        Description="Modifier key + mouse window move/resize utility for Windows"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png" />
    </Application>
  </Applications>

  <Capabilities>
    <!-- Required for Win32 Desktop Bridge apps -->
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>

</Package>
