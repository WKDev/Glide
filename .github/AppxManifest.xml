<?xml version="1.0" encoding="utf-8"?>
<!--
  AppxManifest template for MSIX packaging.
  {{PUBLISHER}}, {{VERSION}}, {{IDENTITY_NAME}}, and {{PUBLISHER_DISPLAY_NAME}}
  are replaced at build time by the release workflow.

  GitHub Secrets (from Partner Center > Product Identity):
    - MSIX_PUBLISHER:              Package/Identity/Publisher (e.g. "CN=00000000-...")
    - MSIX_IDENTITY_NAME:          Package/Identity/Name (e.g. "12345Publisher.Glide")
    - MSIX_PUBLISHER_DISPLAY_NAME: Package/Properties/PublisherDisplayName

  If secrets are unset, defaults are used for local/sideload builds.
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap3 rescap">

  <Identity
    Name="{{IDENTITY_NAME}}"
    Publisher="{{PUBLISHER}}"
    Version="{{VERSION}}"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Glide</DisplayName>
    <PublisherDisplayName>{{PUBLISHER_DISPLAY_NAME}}</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily
      Name="Windows.Desktop"
      MinVersion="10.0.17763.0"
      MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-US" />
  </Resources>

  <Applications>
    <Application Id="Glide" Executable="glide.exe" EntryPoint="Windows.FullTrustApplication">
      <uap3:VisualElements
        DisplayName="Glide"
        Description="Modifier key + mouse window move/resize utility for Windows"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png" />
    </Application>
  </Applications>

  <Capabilities>
    <!-- Required for Win32 Desktop Bridge apps -->
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>

</Package>
