{
  "name": "glide",
  "version": "0.2.0",
  "description": "Modifier key + mouse window move/resize utility for Windows",
  "type": "module",
  "author": "wkdev",
  "homepage": "https://github.com/wkdev/glide",
  "repository": {
    "type": "git",
    "url": "https://github.com/wkdev/glide.git"
  },
  "keywords": [
    "windows",
    "window-manager",
    "mouse",
    "keyboard",
    "utility",
    "tauri"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "bits-ui": "^2.16.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "eslint": "^10.0.2",
    "eslint-plugin-svelte": "^3.15.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "svelte": "^5.53.5",
    "svelte-check": "^4.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.0.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "svelte": ">=5.53.5"
    }
  }
}
